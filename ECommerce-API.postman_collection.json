{
  "info": {
    "name": "E-Commerce API (Code-Verified)",
    "_postman_id": "ecommerce-api-verified-v1",
    "description": "Complete Postman collection built by direct inspection of all Next.js API route files. Auth is HTTP-only cookie based via `token` cookie set by login/register. NO Bearer header is used.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000", "type": "string" }
