            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/changepassword", "host": ["{{base_url}}"], "path": ["api", "auth", "changepassword"] },
