  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api", "auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"1234567890\"\n}"
            }
          },
          "response": [
            {
              "name": "Success (201)",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"success\": true,\n  \"message\": \"User created successfully\",\n  \"data\": { \"id\": \"...\", \"name\": \"Test User\", \"email\": \"test@example.com\", \"role\": \"USER\" }\n}"
            },
            {
              "name": "Validation Error (400) - Zod",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"success\": false,\n  \"message\": \"Password must be at least 6 characters\"\n}"
            },
            {
              "name": "Duplicate Email (400)",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"success\": false,\n  \"message\": \"User already exists\"\n}"
            }
          ]
        },
        {
          "name": "Register User - Invalid (missing phone)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api", "auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test\",\n  \"email\": \"bad@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "description": "Should return 400 with Zod validation error for missing phone field."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Cookie 'token' is automatically set by the server as httpOnly.",
                  "// Postman's cookie jar will persist it for subsequent requests.",
                  "pm.test('Login successful', function () {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.success).to.be.true;",
                  "  pm.expect(json.data).to.have.property('id');",
                  "  pm.expect(json.data).to.have.property('role');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "response": [
            {
              "name": "Success (200)",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Login successful\",\n  \"data\": { \"id\": \"...\", \"name\": \"Test User\", \"email\": \"test@example.com\", \"role\": \"USER\" }\n}"
            },
            {
              "name": "User Not Found (404)",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"success\": false,\n  \"message\": \"User not found\"\n}"
            },
            {
              "name": "Invalid Password (401)",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"success\": false,\n  \"message\": \"Invalid password\"\n}"
            }
          ]
        },
        {
